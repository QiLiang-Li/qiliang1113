{
  "expo": {
    "name": "招财猫",
    "slug": "diary-finance-app",
    "version": "1.3",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "diaryfinance",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F5F2"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.diaryfinance.app"
    },
    "android": {
      "versionCode": 8,
      "permissions": ["android.permission.REQUEST_INSTALL_PACKAGES"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F7F5F2"
      },
      "package": "com.diaryfinance.app"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "eas": {
        "projectId": "7fc269f3-c446-4236-bf21-f994524442af"
      }
    }
  }
}
